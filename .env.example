# OpenUnum Qwen Configuration

# Model Provider (ollama, openai, anthropic, nvidia, ollama-cloud)
PROVIDER=ollama

# Model ID (e.g., qwen3.5:9b-64k, gpt-4o, claude-3.5-sonnet)
MODEL=qwen3.5:9b-64k

# Provider Base URL
BASE_URL=http://127.0.0.1:11434/v1

# API Key (if required by provider)
API_KEY=

# Fallback Model (for automatic failover)
FALLBACK_MODEL=minimax-m2.5:cloud

# Fallback Base URL
FALLBACK_BASE_URL=http://127.0.0.1:11434/v1

# UI Settings
UI_PORT=18880
UI_HOST=127.0.0.1

# Browser Settings (for web tools)
BROWSER_MODE=playwright
CDP_PORT=9333

# Git Sync (GitHub repo for auto-sync)
GITHUB_TOKEN=
GITHUB_REPO=corpunum/openunumQwen
GITHUB_BRANCH=main

# Health Check Interval (ms)
HEALTH_INTERVAL=30000

# Circuit Breaker Settings
CB_FAILURE_THRESHOLD=3
CB_RESET_TIMEOUT=300000

# Memory Settings
MEMORY_DB_PATH=./data/memory.db
BM25_INDEX_PATH=./data/bm25_index.json

# Logging
LOG_LEVEL=info
LOG_PATH=./logs
